rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Lock down all documents by default
    match /{document=**} {
      allow read, write: if false;
    }

    // User data is partitioned by UID
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      // Subcollections (meals, moods, symptoms)
      match /{allPaths=**} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
    }

    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Global Ingredient Data (Read-only for all authenticated users)
    match /ingredients/{id} {
      allow read: if request.auth != null;
    }
    match /ingredient_aliases/{id} {
      allow read: if request.auth != null;
    }
    match /ingredient_relations/{id} {
      allow read: if request.auth != null;
    }
    match /ingredient_flags/{id} {
      allow read: if request.auth != null;
    }
    match /dish_ingredient_priors/{id} {
      allow read: if request.auth != null;
    }
  }
}
